public ResponseEntity<?> handleBalance(InsufficientBalanceException ex) {
    return ResponseEntity.status(HttpStatus.BAD_REQUEST)
            .body(new ErrorResponse("INSUFFICIENT_BALANCE", ex.getMessage()));
}

