⚙️ Service — Isolation Demo
@Service
@RequiredArgsConstructor
public class IsolationService {

    private final AccountRepository repo;

    // Transaction 1
    @Transactional(isolation = Isolation.READ_COMMITTED)
    public void transaction1() throws Exception {

        Account acc1 = repo.findById(1L).orElseThrow();
        System.out.println("Tx1 First Read: " + acc1.getBalance());

        Thread.sleep(5000); // wait for Tx2 update

        Account acc2 = repo.findById(1L).orElseThrow();
        System.out.println("Tx1 Second Read: " + acc2.getBalance());
    }

    // Transaction 2
    @Transactional
    public void transaction2() {

        Account acc = repo.findById(1L).orElseThrow();
        acc.setBalance(500);
        repo.save(acc);

        System.out.println("Tx2 Updated Balance to 500");
    }
}

