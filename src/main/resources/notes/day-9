public void transferWithNewTx(Long fromId, Long toId, Double amount) {

    AccountEntity from = accountRepo.findById(fromId)
            .orElseThrow(() -> new RuntimeException("From not found"));

    AccountEntity to = accountRepo.findById(toId)
            .orElseThrow(() -> new RuntimeException("To not found"));

    if (from.getBalance() < amount) {
        throw new RuntimeException("Insufficient balance");
    }

    from.setBalance(from.getBalance() - amount);
    to.setBalance(to.getBalance() + amount);

    accountRepo.save(from);
    accountRepo.save(to);
}

