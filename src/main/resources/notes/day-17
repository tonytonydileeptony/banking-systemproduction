4️⃣ Audit Logging Using AOP (Clean Architecture)

We do NOT mix audit logic inside business code.

Step 1: Create Audit Annotation
Audit.java
@Target(ElementType.METHOD)
@Retention(RetentionPolicy.RUNTIME)
public @interface Audit {
    String action();
}

Step 2: Audit Aspect
@Aspect
@Component
@Slf4j
@RequiredArgsConstructor
public class AuditAspect {

    private final AuditRepository auditRepository;

    @Around("@annotation(audit)")
    public Object audit(ProceedingJoinPoint joinPoint,
                        Audit audit) throws Throwable {

        String correlationId = MDC.get("correlationId");

        log.info("AUDIT START - {}", audit.action());

        Object result = joinPoint.proceed();

        AuditLog logEntity = new AuditLog();
        logEntity.setAction(audit.action());
        logEntity.setCorrelationId(correlationId);
        logEntity.setTimestamp(LocalDateTime.now());

        auditRepository.save(logEntity);

        log.info("AUDIT END - {}", audit.action());

        return result;
    }
}

